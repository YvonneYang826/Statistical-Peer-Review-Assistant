&lt;tps:template xmlns:tps="http://www.typefi.com/TemplateXML" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="4.4" xsi:schemaLocation="http://www.typefi.com/TemplateXML http://www.typefi.com/TPS/template/4_4/TemplateXML.xsd"&gt;
    
    
    &lt;!-- =================== --&gt;
    &lt;!-- Document Definition --&gt;
    &lt;!-- =================== --&gt;
    
    &lt;tps:definition tag="documentDef"&gt;
        &lt;tps:documentDef&gt;
            &lt;tps:facingPages&gt;true&lt;/tps:facingPages&gt;
        &lt;/tps:documentDef&gt;
    &lt;/tps:definition&gt;
    
    
    &lt;!-- =========================== --&gt;
    &lt;!-- Character Style Definitions --&gt;
    &lt;!-- =========================== --&gt;
    
    &lt;tps:definition tag="charStyleDef"&gt;
        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;bold&lt;/tps:name&gt;
            &lt;tps:basedOn&gt;*&lt;/tps:basedOn&gt;
            &lt;tps:font&gt;
                &lt;tps:name/&gt;
                &lt;tps:style&gt;Bold&lt;/tps:style&gt;
            &lt;/tps:font&gt;
            &lt;tps:leading&gt;0 pt&lt;/tps:leading&gt;
        &lt;/tps:charStyleDef&gt;
    &lt;/tps:definition&gt;
    &lt;tps:definition tag="charStyleDef"&gt;
        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;bold_italic&lt;/tps:name&gt;
            &lt;tps:basedOn&gt;*&lt;/tps:basedOn&gt;
            &lt;tps:font&gt;
                &lt;tps:name/&gt;
                &lt;tps:style&gt;Bold Italic&lt;/tps:style&gt;
            &lt;/tps:font&gt;
            &lt;tps:leading&gt;0 pt&lt;/tps:leading&gt;
        &lt;/tps:charStyleDef&gt;
    &lt;/tps:definition&gt;
    &lt;tps:definition tag="charStyleDef"&gt;
        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;chinese&lt;/tps:name&gt;
            &lt;tps:basedOn&gt;*&lt;/tps:basedOn&gt;
            &lt;tps:font&gt;
                &lt;tps:name&gt;SimSun&lt;/tps:name&gt;
                &lt;tps:style&gt;Regular&lt;/tps:style&gt;
            &lt;/tps:font&gt;
            &lt;tps:leading&gt;0 pt&lt;/tps:leading&gt;
        &lt;/tps:charStyleDef&gt;
    &lt;/tps:definition&gt;
    &lt;tps:definition tag="charStyleDef"&gt;
        &lt;tps:charStyleDef&gt;
            &lt;tps:name&gt;cite_app&lt;/tps:name&gt;
